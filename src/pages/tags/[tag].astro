---
import type { GetStaticPaths } from "astro";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import HomeHeader from "../../components/HomeHeader.astro";
import MaxWidthContainer from "../../components/MaxWidthContainer.astro";
import PostItem from "../../islands/PostItemIsland.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import { getTagGroups } from "../../lib/posts";

export const getStaticPaths = (async () => {
  const tagGroups = await getTagGroups();

  return tagGroups.map((group) => ({
    params: { tag: group.slug },
    props: { tag: group.tag, posts: group.posts },
  }));
}) satisfies GetStaticPaths;

const { tag, posts } = Astro.props;
---

<html lang="ja">
  <head>
    <BaseHead
      title={`#${tag} | ${SITE_TITLE}`}
      description={SITE_DESCRIPTION}
    />
    <style>
      main {
        padding: 0 var(--space-page-inline) var(--space-page-block-end);
      }
      h1 {
        margin-bottom: var(--space-lg);
      }
    </style>
  </head>
  <body>
    <HomeHeader />
    <MaxWidthContainer>
      <main>
        <h1>#{tag}</h1>
        <section class="posts">
          {
            posts.map((post) => (
              <PostItem
                title={post.data.title}
                date={post.data.date}
                href={`/post/${post.id}`}
              />
            ))
          }
        </section>
      </main>
    </MaxWidthContainer>
    <Footer />
  </body>
</html>
