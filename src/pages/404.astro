---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import MaxWidthContainer from "../components/MaxWidthContainer.astro";
import ButtonLinkIsland from "../islands/ButtonLinkIsland.astro";
import "../styles/layout.css";
import "../styles/pages/404.css";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<html lang="ja">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} noindex />
  </head>
  <body>
    <MaxWidthContainer>
      <main class="layout-main not-found">
        <h1>PAGE NOT FOUND</h1>
        <div class="glitch">
          <div class="glitch__img"></div>
          <div class="glitch__img"></div>
          <div class="glitch__img"></div>
          <div class="glitch__img"></div>
          <div class="glitch__img"></div>
        </div>

        <ButtonLinkIsland
          href="/"
          intent="brand"
          appearance="solid"
          size="md"
          className="back-to-home"
        >
          Back to Home
        </ButtonLinkIsland>
      </main>
    </MaxWidthContainer>
    <Footer />
  </body>
</html>
