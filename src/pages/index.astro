---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import HomeHeader from "../components/HomeHeader.astro";
import MaxWidthContainer from "../components/MaxWidthContainer.astro";
import ButtonLinkIsland from "../islands/ButtonLinkIsland.astro";
import PostItemIsland from "../islands/PostItemIsland.astro";
import "../styles/layout.css";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { getPublishedPosts } from "../domain/posts/query";

const latestPosts = (await getPublishedPosts()).slice(0, 5);
---

<html lang="ja">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <HomeHeader />
    <MaxWidthContainer>
      <main class="layout-main">
        <section class="layout-posts layout-posts--spaced">
          {
            latestPosts.map((post) => (
              <PostItemIsland
                href={`/post/${post.data.slug}`}
                title={post.data.title}
                date={post.data.date}
              />
            ))
          }
        </section>

        <ButtonLinkIsland
          href="/page/1"
          intent="brand"
          appearance="solid"
          size="md"
        >
          View all
        </ButtonLinkIsland>
      </main>
    </MaxWidthContainer>
    <Footer />
  </body>
</html>
