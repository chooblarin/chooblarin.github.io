---
import type { GetStaticPaths } from "astro";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import HomeHeader from "../../components/HomeHeader.astro";
import ButtonLinkIsland from "../../components/islands/ButtonLinkIsland.astro";
import PostItemIsland from "../../components/islands/PostItemIsland.astro";
import MaxWidthContainer from "../../components/MaxWidthContainer.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import { getPublishedPosts } from "../../lib/posts";

export const getStaticPaths = (async () => {
  const posts = await getPublishedPosts();
  const countPerPage = 10;
  const pageSize = Math.ceil(posts.length / countPerPage);
  const chunked = Array.from({ length: pageSize }, (_, i) =>
    posts.slice(i * countPerPage, i * countPerPage + countPerPage),
  );

  return chunked.map((chunk, index) => ({
    params: { p: (index + 1).toString() },
    props: {
      chunk,
      hasPrev: index - 1 >= 0,
      hasNext: index + 1 < chunked.length,
      page: index + 1,
    },
  }));
}) satisfies GetStaticPaths;

const { chunk, hasNext, hasPrev, page } = Astro.props;
---

<html lang="ja">
  <head>
    <BaseHead
      title={`記事一覧 ${page}ページ目 | ${SITE_TITLE}`}
      description={SITE_DESCRIPTION}
    />
    <style>
      main {
        padding: 0 16px 96px;
      }
      .posts {
        display: grid;
        gap: 12px;
      }
      .links {
        display: flex;
        gap: 12px;
        margin: 48px 0;
      }
    </style>
  </head>
  <body>
    <HomeHeader />
    <MaxWidthContainer>
      <main>
        <section class="posts">
          {
            chunk.map((post) => (
              <PostItemIsland
                href={`/post/${post.data.slug}`}
                title={post.data.title}
                date={post.data.date}
              />
            ))
          }
        </section>
        {
          (hasPrev || hasNext) && (
            <div class="links">
              {hasPrev && (
                <ButtonLinkIsland
                  href={`/page/${page - 1}`}
                  intent="neutral"
                  appearance="outline"
                >
                  前へ
                </ButtonLinkIsland>
              )}
              {hasNext && (
                <ButtonLinkIsland
                  href={`/page/${page + 1}`}
                  intent="neutral"
                  appearance="outline"
                >
                  次へ
                </ButtonLinkIsland>
              )}
            </div>
          )
        }
      </main>
    </MaxWidthContainer>
    <Footer />
  </body>
</html>
