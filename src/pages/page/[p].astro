---
import type { GetStaticPaths } from "astro";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import HomeHeader from "../../components/HomeHeader.astro";
import MaxWidthContainer from "../../components/MaxWidthContainer.astro";
import PaginationNav from "../../islands/PaginationNavIsland.astro";
import PostItem from "../../islands/PostItemIsland.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import { getPostPages } from "../../lib/posts";

export const getStaticPaths = (async () => {
  const pages = await getPostPages();

  return pages.map((page) => ({
    params: { p: page.page.toString() },
    props: page,
  }));
}) satisfies GetStaticPaths;

const { posts, hasNext, hasPrev, page } = Astro.props;
---

<html lang="ja">
  <head>
    <BaseHead
      title={`記事一覧 ${page}ページ目 | ${SITE_TITLE}`}
      description={SITE_DESCRIPTION}
    />
    <style>
      main {
        padding: 0 var(--space-page-inline) var(--space-page-block-end);
      }
    </style>
  </head>
  <body>
    <HomeHeader />
    <MaxWidthContainer>
      <main>
        <section>
          {
            posts.map((post) => (
              <PostItem
                title={post.data.title}
                date={post.data.date}
                href={`/post/${post.id}`}
              />
            ))
          }
        </section>
        <PaginationNav
          prevHref={hasPrev ? `/page/${page - 1}` : undefined}
          nextHref={hasNext ? `/page/${page + 1}` : undefined}
        />
      </main>
    </MaxWidthContainer>
    <Footer />
  </body>
</html>
