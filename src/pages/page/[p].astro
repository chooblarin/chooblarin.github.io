---
import type { GetStaticPaths } from "astro";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import HomeHeader from "../../components/HomeHeader.astro";
import MaxWidthContainer from "../../components/MaxWidthContainer.astro";
import PaginationNavIsland from "../../islands/PaginationNavIsland.astro";
import PostItemIsland from "../../islands/PostItemIsland.astro";
import "../../styles/layout.css";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import { getPublishedPosts } from "../../domain/posts/query";

export const getStaticPaths = (async () => {
  const posts = await getPublishedPosts();
  const countPerPage = 10;
  const pageSize = Math.ceil(posts.length / countPerPage);
  const chunked = Array.from({ length: pageSize }, (_, i) =>
    posts.slice(i * countPerPage, i * countPerPage + countPerPage),
  );

  return chunked.map((chunk, index) => ({
    params: { p: (index + 1).toString() },
    props: {
      chunk,
      hasPrev: index - 1 >= 0,
      hasNext: index + 1 < chunked.length,
      page: index + 1,
    },
  }));
}) satisfies GetStaticPaths;

const { chunk, hasNext, hasPrev, page } = Astro.props;
---

<html lang="ja">
  <head>
    <BaseHead
      title={`記事一覧 ${page}ページ目 | ${SITE_TITLE}`}
      description={SITE_DESCRIPTION}
    />
  </head>
  <body>
    <HomeHeader />
    <MaxWidthContainer>
      <main class="layout-main">
        <section class="layout-posts">
          {
            chunk.map((post) => (
              <PostItemIsland
                href={`/post/${post.data.slug}`}
                title={post.data.title}
                date={post.data.date}
              />
            ))
          }
        </section>
        <div class="layout-pagination">
          <PaginationNavIsland
            prevHref={hasPrev ? `/page/${page - 1}` : undefined}
            nextHref={hasNext ? `/page/${page + 1}` : undefined}
            prevLabel="前へ"
            nextLabel="次へ"
          />
        </div>
      </main>
    </MaxWidthContainer>
    <Footer />
  </body>
</html>
