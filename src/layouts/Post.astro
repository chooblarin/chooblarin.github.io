---
import "@fontsource-variable/jetbrains-mono";
import type { MarkdownHeading } from "astro";
import type { CollectionEntry } from "astro:content";
import { format } from "date-fns";
import type { TableOfContentsHeading } from "../design-system/react/composites/TableOfContents";

import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import LinkIsland from "../components/islands/LinkIsland.astro";
import PostNavCardIsland from "../components/islands/PostNavCardIsland.astro";
import TableOfContentsIsland from "../components/islands/TableOfContentsIsland.astro";
import Logo from "../components/Logo.astro";
import MaxWidthContainer from "../components/MaxWidthContainer.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { slugify } from "../lib/util";

type Props = {
  post: CollectionEntry<"post">;
  headings: MarkdownHeading[];
  previousPost: {
    slug: string;
    title: string;
    date: Date;
  } | null;
};

const { post, headings, previousPost } = Astro.props;
const { title, date, tags, image, description, embeds, updatedAt } = post.data;
const formattedDate = format(date, "yyyy-MM-dd");
const metaDescription = description || SITE_DESCRIPTION;
const hasTwitterEmbed = embeds?.includes("twitter") ?? false;
const hasCodePenEmbed = embeds?.includes("codepen") ?? false;

const tagItems = tags.map((name) => ({
  name,
  slug: slugify(name),
}));

const tableOfContentsHeadings: TableOfContentsHeading[] = headings.flatMap(
  (heading) =>
    heading.depth === 2 || heading.depth === 3
      ? [
          {
            id: heading.slug,
            text: heading.text,
            depth: heading.depth,
          },
        ]
      : []
);
const hasTableOfContents = tableOfContentsHeadings.length > 0;
---

<html lang="ja">
  <head>
    <BaseHead
      title={`${title} | ${SITE_TITLE}`}
      description={metaDescription}
      image={image}
      ogType="article"
      publishedTime={date.toISOString()}
      modifiedTime={(updatedAt ?? date).toISOString()}
    />
    <style is:inline>
      header {
        display: flex;
        justify-content: center;
        margin-top: 44px;
        margin-bottom: 64px;
      }
      main {
        padding: 0 16px 44px;
      }
      article {
        --base-width: 740px;
        flex: 1 1 auto;
        width: min(var(--base-width), 100%);
        max-width: min(var(--base-width), 100%);
        min-width: 0;
      }
      .logo {
        width: fit-content;
        border-bottom: 1px solid rgb(209 213 219);
        padding: 8px;
      }
      .post-content {
        code {
          font-family: "JetBrains Mono Variable", "Menlo", "Courier", monospace;
          font-size: 0.875em;
        }

        /* Code hightlight */
        :not(pre) > code {
          background: #f3f4f6;
          border-radius: 4px;
          padding: 2px 6px;
        }
        pre:has(code) {
          padding: 0.8rem;
          border: 2px solid #aaa;
          border-radius: 4px;
          scrollbar-width: none; /* Firefox */
          &::-webkit-scrollbar {
            display: none; /* Safari and Chrome */
          }
        }
      }
      .post-layout {
        display: flex;
        flex-direction: row-reverse;
        justify-content: center;
      }
      .post-toc {
        display: none;
      }
      .title {
        display: inline-block;
        background: linear-gradient(
          90deg,
          rgb(59, 154, 201),
          rgb(152, 59, 201)
        );
        background-clip: text;
        -webkit-background-clip: text;
        font-size: 2rem;
        font-weight: 600;
        color: transparent;
      }
      .date {
        font-size: 0.875rem;
        margin: 48px 0 24px;
        color: rgb(75 85 99);
      }
      .thumbnail {
        margin: 32px 0 24px;
      }
      .thumbnail img {
        width: 100%;
        max-width: 100%;
        height: auto;
        border-radius: 10px;
      }
      .tags {
        margin: 24px 0;
      }
      .tag {
        display: inline-block;
        margin: 8px 8px 8px 0;
      }
      .tag a {
        font-size: 0.75rem;
        color: rgb(75 85 99);
        background-color: rgb(243 244 246);
        text-decoration: none;
        border-radius: 4px;
        padding: 6px 12px;
      }
      .content {
        margin-top: 64px;
      }
      .post-nav {
        margin-top: 48px;
      }
      @media (min-width: 68.75rem) {
        .post-toc {
          display: block;
        }
      }
    </style>

    {
      hasTwitterEmbed && (
        <script
          is:inline
          async
          src="https://platform.twitter.com/widgets.js"
        ></script>
      )
    }
    {
      hasCodePenEmbed && (
        <script
          is:inline
          async
          src="https://cpwebassets.codepen.io/assets/embed/ei.js"></script>
      )
    }

    <!-- KaTeX styles -->
    <link rel="stylesheet" href="/styles/katex/katex.min.css" rel="preload" />
  </head>
  <body>
    <MaxWidthContainer width="68.75rem">
      <main>
        <header>
          <div class="logo">
            <Logo />
          </div>
        </header>
        <div class="post-layout">
          {
            hasTableOfContents && (
              <TableOfContentsIsland
                headings={tableOfContentsHeadings}
                stickyTop={128}
                className="post-toc"
              />
            )
          }
          <article>
            <h1 class="title">{title}</h1>
            {
              image && (
                <figure class="thumbnail">
                  <img src={image} alt={`${title} thumbnail`} />
                </figure>
              )
            }
            <p class="date">{formattedDate}</p>
            <ul class="tags">
              {
                tagItems.map((tag) => (
                  <li class="tag">
                    <LinkIsland href={`/tags/${tag.slug}`} decoration="none">
                      {`#${tag.name}`}
                    </LinkIsland>
                  </li>
                ))
              }
            </ul>
            <div class="post-content">
              <slot />
            </div>
            {
              previousPost && (
                <nav class="post-nav" aria-label="前の記事">
                  <PostNavCardIsland
                    href={`/post/${previousPost.slug}`}
                    label="前の記事"
                    title={previousPost.title}
                    date={previousPost.date}
                  />
                </nav>
              )
            }
          </article>
        </div>
      </main>
    </MaxWidthContainer>

    <Footer />
  </body>
</html>
