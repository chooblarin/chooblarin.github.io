---
import "@fontsource-variable/jetbrains-mono";
import type { CollectionEntry } from "astro:content";
import type { MarkdownHeading } from "astro";
import { format } from "date-fns";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import HomeHeader from "../components/HomeHeader.astro";
import MaxWidthContainer from "../components/MaxWidthContainer.astro";
import PostNavCardIsland from "../islands/PostNavCardIsland.astro";
import TableOfContentsIsland from "../islands/TableOfContentsIsland.astro";
import TagListIsland from "../islands/TagListIsland.astro";
import "../styles/layout.css";
import "../styles/layouts/post.css";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import type { TableOfContentsHeading } from "../design-system/react/patterns/TableOfContents";
import { slugify } from "../domain/posts/tag";

type Props = {
  post: CollectionEntry<"post">;
  headings: MarkdownHeading[];
  previousPost: {
    slug: string;
    title: string;
    date: Date;
  } | null;
};

const { post, headings, previousPost } = Astro.props;
const { title, date, tags, image, description, embeds, updatedAt } = post.data;
const formattedDate = format(date, "yyyy-MM-dd");
const metaDescription = description || SITE_DESCRIPTION;
const hasTwitterEmbed = embeds?.includes("twitter") ?? false;
const hasCodePenEmbed = embeds?.includes("codepen") ?? false;

const tagItems = tags.map((tag) => ({
  label: `#${tag}`,
  href: `/tags/${slugify(tag)}`,
}));

const tableOfContentsHeadings: TableOfContentsHeading[] = headings.flatMap(
  (heading) =>
    heading.depth === 2 || heading.depth === 3
      ? [
          {
            id: heading.slug,
            text: heading.text,
            depth: heading.depth,
          },
        ]
      : [],
);
const hasTableOfContents = tableOfContentsHeadings.length > 0;
---

<html lang="ja">
  <head>
    <BaseHead
      title={`${title} | ${SITE_TITLE}`}
      description={metaDescription}
      image={image}
      ogType="article"
      publishedTime={date.toISOString()}
      modifiedTime={(updatedAt ?? date).toISOString()}
    />
    {
      hasTwitterEmbed && (
        <script is:inline async src="https://platform.twitter.com/widgets.js" />
      )
    }
    {
      hasCodePenEmbed && (
        <script
          is:inline
          async
          src="https://cpwebassets.codepen.io/assets/embed/ei.js"
        />
      )
    }

    <!-- KaTeX styles -->
    <link rel="stylesheet" href="/styles/katex/katex.min.css" rel="preload" />
  </head>
  <body>
    <MaxWidthContainer width="68.75rem">
      <main class="layout-main layout-main--post">
        <HomeHeader />
        <div
          class={`post-layout${hasTableOfContents ? " post-layout--with-toc" : ""}`}
        >
          {
            hasTableOfContents && (
              <TableOfContentsIsland
                headings={tableOfContentsHeadings}
                stickyTop={128}
                className="post-toc"
              />
            )
          }
          <article class="post-article">
            <h1 class="post-title">{title}</h1>
            {
              image && (
                <figure class="post-thumbnail">
                  <img src={image} alt={`${title} thumbnail`} />
                </figure>
              )
            }
            <p class="post-date">{formattedDate}</p>
            <TagListIsland items={tagItems} variant="chip" className="post-tags" />
            <div class="post-content">
              <slot />
            </div>
            {
              previousPost && (
                <nav class="post-nav" aria-label="前の記事">
                  <PostNavCardIsland
                    href={`/post/${previousPost.slug}`}
                    label="前の記事"
                    title={previousPost.title}
                    date={previousPost.date}
                  />
                </nav>
              )
            }
          </article>
        </div>
      </main>
    </MaxWidthContainer>

    <Footer />
  </body>
</html>
