---
import "@fontsource-variable/jetbrains-mono";
import type { MarkdownHeading } from "astro";
import type { CollectionEntry } from "astro:content";

import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Logo from "../components/Logo.astro";
import MaxWidthContainer from "../components/MaxWidthContainer.astro";
import PostNavCardIsland from "../islands/PostNavCardIsland.astro";
import TableOfContentsIsland from "../islands/TableOfContentsIsland.astro";
import TagListIsland from "../islands/TagListIsland.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { formatDisplayDate } from "../lib/date";
import { slugify } from "../lib/util";

type Props = {
  post: CollectionEntry<"post">;
  prev: CollectionEntry<"post"> | null;
  next: CollectionEntry<"post"> | null;
  headings: MarkdownHeading[];
};

const { post, prev, next, headings } = Astro.props;
const { title, date, tags, description, image } = post.data;
const formattedDate = formatDisplayDate(date);

const tagItems = tags.map((name) => ({
  name,
  slug: slugify(name),
}));

// Only load heavy third-party assets on the posts that actually need them.
// Content Layer types `body` as string | undefined.
const body = post.body ?? "";
const needsTwitter = /twitter-tweet/i.test(body);
const needsCodePen = /codepen\.io|class="codepen/i.test(body);
const needsKatex = /\$\$[\s\S]+\$\$|(?<!\\)\$[^$\n]+\$/.test(body);

const canonicalURL = new URL(`/post/${post.id}/`, Astro.site);
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  datePublished: date.toISOString(),
  description: description ?? SITE_DESCRIPTION,
  ...(image ? { image: new URL(image, Astro.site).href } : {}),
  author: { "@type": "Person", name: "Sota Hatakeyama" },
  keywords: tags.join(", "),
  mainEntityOfPage: { "@type": "WebPage", "@id": canonicalURL.href },
  url: canonicalURL.href,
};
---

<html lang="ja">
  <head>
    <BaseHead
      title={`${title} | ${SITE_TITLE}`}
      description={description ?? SITE_DESCRIPTION}
      image={image}
      type="article"
      publishedTime={date}
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(jsonLd)}
    />
    <style>
      header {
        display: flex;
        justify-content: center;
        margin-block: var(--space-header-block-start)
          var(--space-header-block-end);
      }
      main {
        padding: 0 var(--space-page-inline) var(--space-section-gap);
      }
      .logo {
        min-width: 0;
        border-bottom: 1px solid var(--color-border);
        padding: var(--space-xs);
      }
      .post-columns {
        display: flex;
        flex-direction: row-reverse;
        justify-content: center;
      }
      .title {
        display: inline-block;
        background: linear-gradient(
          90deg,
          var(--color-deep),
          var(--color-primary) 60%,
          var(--color-accent)
        );
        background-clip: text;
        -webkit-background-clip: text;
        font-size: 2rem;
        font-weight: 600;
        color: transparent;
      }
      .date {
        font-size: 0.875rem;
        margin: var(--space-2xl) 0 var(--space-lg);
        color: var(--color-text-muted);
      }
      .tags {
        margin: var(--space-lg) 0;
      }
      .post-nav {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-md);
        margin: var(--space-3xl) 0 var(--space-section-gap);
      }
      .post-nav :global(.post-nav-next) {
        grid-column: 2;
      }
      @media (max-width: 36rem) {
        .post-nav {
          grid-template-columns: 1fr;
        }
        .post-nav :global(.post-nav-next) {
          grid-column: 1;
        }
      }
    </style>

    {/* Twitter widget */}
    {
      needsTwitter && (
        <script is:inline async src="https://platform.twitter.com/widgets.js" />
      )
    }

    {/* CodePen */}
    {
      needsCodePen && (
        <script
          is:inline
          async
          src="https://cpwebassets.codepen.io/assets/embed/ei.js"
        />
      )
    }

    {/* KaTeX styles */}
    {needsKatex && <link rel="stylesheet" href="/styles/katex/katex.min.css" />}
  </head>
  <body>
    <MaxWidthContainer width="68.75rem">
      <main>
        <header>
          <div class="logo">
            <Logo />
          </div>
        </header>
        <div class="post-columns">
          <TableOfContentsIsland headings={headings} />
          <article class="post-article">
            <h1 class="title">{title}</h1>
            <p class="date">{formattedDate}</p>
            <div class="tags">
              <TagListIsland
                items={tagItems.map((tag) => ({
                  label: `#${tag.name}`,
                  href: `/tags/${tag.slug}`,
                }))}
              />
            </div>
            <div class="article-prose">
              <slot />
            </div>
            {
              (prev || next) && (
                <nav class="post-nav" aria-label="前後の記事">
                  {prev && (
                    <PostNavCardIsland
                      href={`/post/${prev.id}`}
                      label="前の記事"
                      title={prev.data.title}
                      date={prev.data.date}
                    />
                  )}
                  {next && (
                    <PostNavCardIsland
                      className="post-nav-next"
                      href={`/post/${next.id}`}
                      label="次の記事"
                      title={next.data.title}
                      date={next.data.date}
                    />
                  )}
                </nav>
              )
            }
          </article>
        </div>
      </main>
    </MaxWidthContainer>

    <Footer />
  </body>
</html>
