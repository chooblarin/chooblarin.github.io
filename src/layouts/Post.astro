---
import "@fontsource-variable/jetbrains-mono";
import type { MarkdownHeading } from "astro";
import type { CollectionEntry } from "astro:content";
import { format } from "date-fns";

import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Logo from "../components/Logo.astro";
import MaxWidthContainer from "../components/MaxWidthContainer.astro";
import TableOfContents from "../components/TableOfContents.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { slugify } from "../lib/util";

type Props = {
  post: CollectionEntry<"post">;
  prev: CollectionEntry<"post"> | null;
  next: CollectionEntry<"post"> | null;
  headings: MarkdownHeading[];
};

const { post, prev, next, headings } = Astro.props;
const { title, date, tags, description, image } = post.data;
const formattedDate = format(date, "MMMM dd, yyyy");

const tagItems = tags.map((name) => ({
  name,
  slug: slugify(name),
}));

// Only load heavy third-party assets on the posts that actually need them.
const body = post.body;
const needsTwitter = /twitter-tweet/i.test(body);
const needsCodePen = /codepen\.io|class="codepen/i.test(body);
const needsKatex = /\$\$[\s\S]+\$\$|(?<!\\)\$[^$\n]+\$/.test(body);

const canonicalURL = new URL(`/post/${post.slug}/`, Astro.site);
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  datePublished: date.toISOString(),
  description: description ?? SITE_DESCRIPTION,
  ...(image ? { image: new URL(image, Astro.site).href } : {}),
  author: { "@type": "Person", name: "Sota Hatakeyama" },
  keywords: tags.join(", "),
  mainEntityOfPage: { "@type": "WebPage", "@id": canonicalURL.href },
  url: canonicalURL.href,
};
---

<html lang="ja">
  <head>
    <BaseHead
      title={`${title} | ${SITE_TITLE}`}
      description={description ?? SITE_DESCRIPTION}
      image={image}
      type="article"
      publishedTime={date}
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(jsonLd)}
    />
    <style>
      header {
        display: flex;
        justify-content: center;
        margin-block: var(--space-header-block-start)
          var(--space-header-block-end);
      }
      main {
        padding: 0 var(--space-page-inline) var(--space-section-gap);
      }
      .logo {
        min-width: 0;
        border-bottom: 1px solid var(--color-border);
        padding: var(--space-xs);
      }
      .post-columns {
        display: flex;
        flex-direction: row-reverse;
        justify-content: center;
      }
      .title {
        display: inline-block;
        background: linear-gradient(
          90deg,
          rgb(59, 154, 201),
          rgb(152, 59, 201)
        );
        background-clip: text;
        -webkit-background-clip: text;
        font-size: 2rem;
        font-weight: 600;
        color: transparent;
      }
      .date {
        font-size: 0.875rem;
        margin: var(--space-2xl) 0 var(--space-lg);
        color: var(--color-text-muted);
      }
      .tags {
        margin: var(--space-lg) 0;
      }
      .tag {
        display: inline-block;
        margin: var(--space-xs) var(--space-xs) var(--space-xs) 0;
      }
      .tag a {
        font-size: 0.75rem;
        color: var(--color-text-muted);
        background-color: var(--color-surface);
        text-decoration: none;
        border-radius: var(--radius-sm);
        padding: var(--space-2xs) var(--space-sm);
      }
      .links {
        display: flex;
        justify-content: space-between;
        gap: var(--space-md);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-sm);
        margin: var(--space-3xl) 0 var(--space-section-gap);
        padding: var(--space-md);
      }
      .nav-link {
        font-size: 0.875rem;
        max-width: 45%;
        color: var(--color-text-muted);
        text-decoration: none;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        transition: color 0.2s linear;
      }
      .nav-link:hover {
        color: var(--color-primary);
      }
      .nav-link.next {
        text-align: right;
        margin-left: auto;
      }
    </style>

    {/* Twitter widget */}
    {
      needsTwitter && (
        <script is:inline async src="https://platform.twitter.com/widgets.js" />
      )
    }

    {/* CodePen */}
    {
      needsCodePen && (
        <script
          is:inline
          async
          src="https://cpwebassets.codepen.io/assets/embed/ei.js"
        />
      )
    }

    {/* KaTeX styles */}
    {needsKatex && <link rel="stylesheet" href="/styles/katex/katex.min.css" />}
  </head>
  <body>
    <MaxWidthContainer width="68.75rem">
      <main>
        <header>
          <div class="logo">
            <Logo />
          </div>
        </header>
        <div class="post-columns">
          <TableOfContents headings={headings} />
          <article class="post-article">
            <h1 class="title">{title}</h1>
            <p class="date">{formattedDate}</p>
            <ul class="tags">
              {
                tagItems.map((tag) => (
                  <li class="tag">
                    <a href={`/tags/${tag.slug}`}>{`#${tag.name}`}</a>
                  </li>
                ))
              }
            </ul>
            <div class="article-prose">
              <slot />
            </div>
            {
              (prev || next) && (
                <nav class="links" aria-label="前後の記事">
                  {prev ? (
                    <a class="nav-link prev" href={`/post/${prev.slug}`}>
                      ← {prev.data.title}
                    </a>
                  ) : (
                    <span />
                  )}
                  {next ? (
                    <a class="nav-link next" href={`/post/${next.slug}`}>
                      {next.data.title} →
                    </a>
                  ) : (
                    <span />
                  )}
                </nav>
              )
            }
          </article>
        </div>
      </main>
    </MaxWidthContainer>

    <Footer />
  </body>
</html>
