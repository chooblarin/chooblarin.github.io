---
import Logo from "./Logo.astro";
import ThemeSwitcher from "./ThemeSwitcher.astro";
---

<header>
  <div class="header-spacer" aria-hidden="true"></div>
  <div class="logo">
    <Logo />
  </div>
  <div class="theme-switcher-wrap">
    <ThemeSwitcher />
  </div>
</header>

<style>
  header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    column-gap: 12px;
    max-width: 740px;
    margin: 44px auto 64px;
  }

  .header-spacer {
    min-width: 0;
  }

  .logo {
    width: fit-content;
    justify-self: center;
    border-bottom: 1px solid var(--ds-color-border-light);
    border-bottom: 1px solid var(--ds-color-border);
    padding: 8px;
  }

  .theme-switcher-wrap {
    justify-self: end;
  }

  @media (max-width: 40rem) {
    header {
      margin: 28px auto 48px;
      padding: 0 16px;
      grid-template-columns: auto 1fr;
      grid-template-areas:
        "logo logo"
        ". switcher";
      row-gap: 10px;
      justify-items: center;
    }

    .header-spacer {
      display: none;
    }

    .logo {
      grid-area: logo;
      justify-self: center;
    }

    .theme-switcher-wrap {
      grid-area: switcher;
      justify-self: end;
      width: 100%;
      display: flex;
      justify-content: flex-end;
    }
  }
</style>
