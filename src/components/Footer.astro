---
import MaxWidthContainer from "./MaxWidthContainer.astro";
import ThemeToggle from "./ThemeToggle.astro";

const currentYear = new Date().getFullYear();

// Mirrors the nav on sotahatakeyama.com (Mail / X / GitHub / Instagram).
// `fill` icons paint with currentColor; the rest are lucide-style strokes.
const socialLinks = [
  {
    title: "Mail",
    href: "mailto:hi@sotahatakeyama.com",
    external: false,
    viewBox: "0 0 24 24",
    body: `<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>`,
  },
  {
    title: "X",
    href: "https://x.com/chooblarin",
    external: true,
    fill: true,
    viewBox: "0 0 512 512",
    body: `<path fill="currentColor" d="M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 106.5 464H35.8l164.9-188.5L26.8 48h145.6l100.5 132.9L389.2 48zm-24.8 373.8h39.1L151.1 88h-42l255.3 333.8z"/>`,
  },
  {
    title: "GitHub",
    href: "https://github.com/chooblarin",
    external: true,
    viewBox: "0 0 24 24",
    body: `<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>`,
  },
  {
    title: "Instagram",
    href: "https://www.instagram.com/sotahatakeyama",
    external: true,
    viewBox: "0 0 24 24",
    body: `<rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37zM17.5 6.5h.01"/>`,
  },
];
---

<footer>
  <MaxWidthContainer>
    <div class="footer-inner">
      <nav class="social" aria-label="ソーシャルリンク">
        <ul>
          {
            socialLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="social-link"
                  rel="noreferrer noopener"
                  target={link.external ? "_blank" : undefined}
                >
                  <span class="sr-only">{link.title}</span>
                  <svg
                    width="22"
                    height="22"
                    viewBox={link.viewBox}
                    fill={link.fill ? "currentColor" : "none"}
                    stroke={link.fill ? "none" : "currentColor"}
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    set:html={link.body}
                  />
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <a class="portfolio" href="https://www.sotahatakeyama.com/">
        <span>sotahatakeyama.com</span>
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M7 7h10v10"></path>
          <path d="M7 17 17 7"></path>
        </svg>
      </a>

      <div class="bottom">
        <span class="gutter" aria-hidden="true"></span>
        <p class="copyright">&copy; 2015-{currentYear} sotahatakeyama.</p>
        <div class="gutter actions">
          <ThemeToggle />
        </div>
      </div>
    </div>
  </MaxWidthContainer>
</footer>

<style>
  footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-xl) var(--space-page-inline)
      var(--space-page-block-end);
  }
  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
  }

  /* Social icon row — mirrors the sotahatakeyama.com nav. */
  .social ul {
    display: flex;
    gap: var(--space-xs);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--space-touch-target);
    height: var(--space-touch-target);
    border-radius: var(--radius-md);
    color: var(--color-text-muted);
    transition: color 0.2s linear;
  }
  .social-link:hover {
    color: var(--color-primary);
  }
  .social-link svg {
    display: block;
  }

  /* Link to the personal site itself. */
  .portfolio {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    padding: var(--space-xs) var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    color: var(--color-text-muted);
    font-size: 0.9rem;
    letter-spacing: 0.02rem;
    text-decoration: none;
    transition:
      color 0.2s linear,
      border-color 0.2s linear;
  }
  .portfolio:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }
  .portfolio svg {
    display: block;
    opacity: 0.8;
  }

  /* Bottom row: copyright centered, theme toggle pinned right. */
  .bottom {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    width: 100%;
  }
  .gutter {
    flex: 0 0 var(--space-touch-target);
    display: flex;
  }
  .actions {
    justify-content: flex-end;
  }
  .copyright {
    flex: 1 1 auto;
    margin: 0;
    text-align: center;
    font-size: 1rem;
    color: var(--color-text-muted);
    letter-spacing: 0.05rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
