---
import MaxWidthContainer from "./MaxWidthContainer.astro";

const currentYear = new Date().getFullYear();
---

<footer>
  <MaxWidthContainer>
    <div class="footer-content">
      <p class="copyright">
        &copy; 2015-{currentYear} <a href="https://www.sotahatakeyama.com/" class="me"
          >sotahatakeyama.</a
        >
      </p>
    </div>
  </MaxWidthContainer>
</footer>

<style>
  footer {
    border-top: 1px solid var(--ds-color-border);
    padding: 32px 16px;
  }
  .footer-content {
    place-items: center;
    padding: 0 16px 96px;
  }
  .copyright {
    font-size: 1rem;
    color: var(--ds-color-text-muted);
    letter-spacing: 0.05rem;
  }
  .me {
    letter-spacing: 0.1rem;
    color: inherit;
    border-radius: 4px;
    text-decoration: none;
    transition: color 0.2s;
  }
  .me:focus {
    outline: none;
  }
  .me:focus-visible {
    outline: var(--ds-focus-ring-width) solid var(--ds-color-focus-ring);
    outline-offset: var(--ds-focus-ring-offset);
  }
  .me:hover {
    color: var(--ds-color-primary);
    text-decoration: underline;
  }
</style>
