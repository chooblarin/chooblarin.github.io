---
import MaxWidthContainer from "./MaxWidthContainer.astro";
import ThemeToggle from "./ThemeToggle.astro";

const currentYear = new Date().getFullYear();
---

<footer>
  <MaxWidthContainer>
    <div class="footer-content">
      <span class="gutter" aria-hidden="true"></span>
      <p class="copyright">
        &copy; 2015-{currentYear}
        <a href="https://www.sotahatakeyama.com/" class="me">sotahatakeyama.</a>
      </p>
      <div class="gutter actions">
        <ThemeToggle />
      </div>
    </div>
  </MaxWidthContainer>
</footer>

<style>
  footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-xl) var(--space-page-inline);
  }
  .footer-content {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 0 var(--space-page-inline) var(--space-page-block-end);
  }
  /* Equal-width side gutters keep the copyright centered while the toggle
     sits on the right. */
  .gutter {
    flex: 0 0 var(--space-touch-target);
    display: flex;
  }
  .actions {
    justify-content: flex-end;
  }
  .copyright {
    flex: 1 1 auto;
    text-align: center;
    font-size: 1rem;
    color: var(--color-text-muted);
    letter-spacing: 0.05rem;
  }
  .me {
    letter-spacing: 0.1rem;
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }
  .me:hover {
    color: revert;
    text-decoration: underline;
  }
</style>
