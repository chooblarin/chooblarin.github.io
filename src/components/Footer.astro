---
import MaxWidthContainer from "./MaxWidthContainer.astro";
import ThemeToggle from "./ThemeToggle.astro";

const currentYear = new Date().getFullYear();
---

<footer>
  <MaxWidthContainer>
    <div class="footer-content">
      <ThemeToggle />
      <p class="copyright">
        &copy; 2015-{currentYear}
        <a href="https://www.sotahatakeyama.com/" class="me">sotahatakeyama.</a>
      </p>
    </div>
  </MaxWidthContainer>
</footer>

<style>
  footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-xl) var(--space-page-inline);
  }
  .footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    padding: 0 var(--space-page-inline) var(--space-page-block-end);
  }
  .copyright {
    font-size: 1rem;
    color: var(--color-text-muted);
    letter-spacing: 0.05rem;
  }
  .me {
    letter-spacing: 0.1rem;
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }
  .me:hover {
    color: revert;
    text-decoration: underline;
  }
</style>
