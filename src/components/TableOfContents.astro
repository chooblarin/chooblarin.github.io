---
import type { MarkdownHeading } from "astro";

type Props = {
  headings: MarkdownHeading[];
};
const { headings } = Astro.props;
const items = headings.filter((heading) => heading.depth <= 3);
---

{
  items.length > 0 && (
    <aside class="toc">
      <nav aria-label="目次">
        <p class="toc-heading">目次</p>
        {items.map((heading) => (
          <div class={`item depth-${heading.depth}`}>
            <a href={`#${heading.slug}`}>{heading.text}</a>
          </div>
        ))}
      </nav>
    </aside>
  )
}

<script is:inline>
  (function () {
    // This inline script runs during parse, before the article headings
    // (which live in a sibling that comes later in the DOM) exist. Wait for
    // the full document so getElementById can resolve every heading.
    const init = () => {
      const toc = document.querySelector(".toc");
      if (!toc) return;
      const links = Array.from(toc.querySelectorAll("a"));
      const decode = (a) => {
        const raw = a.getAttribute("href").slice(1);
        try {
          return decodeURIComponent(raw);
        } catch {
          return raw;
        }
      };
      const entries = links
        .map((a) => ({
          a,
          item: a.closest(".item"),
          el: document.getElementById(decode(a)),
        }))
        .filter((e) => e.el && e.item);
      if (!entries.length) return;

      let activeId = null;
      const setActive = (id) => {
        if (id === activeId) return;
        activeId = id;
        for (const { a, item } of entries) {
          const on = decode(a) === id;
          item.classList.toggle("active", on);
          if (on) a.setAttribute("aria-current", "true");
          else a.removeAttribute("aria-current");
        }
      };

      // The heading whose top is the last one above the threshold is "current".
      const update = () => {
        const threshold = 120;
        let current = entries[0];
        for (const e of entries) {
          if (e.el.getBoundingClientRect().top <= threshold) current = e;
          else break;
        }
        setActive(decode(current.a));
      };

      let ticking = false;
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          update();
          ticking = false;
        });
      };
      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", onScroll);
      update();
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>

<style>
  .toc {
    --top-offset: calc(
      var(--space-header-block-start) + var(--space-header-block-end) +
        var(--space-lg)
    );
    --toc-pad: var(--space-md);
    display: none;
    /* align-self keeps the aside its natural height inside the flex row so
       position: sticky has room to work (stretch would break it). */
    align-self: flex-start;
    position: sticky;
    top: var(--top-offset);
    /* max-width + padding keep the content width while leaving an inner gutter
       so focus rings / the marker aren't clipped by `overflow`. */
    max-width: 18.5rem;
    max-height: calc(100vh - var(--top-offset) - var(--space-lg));
    overflow: auto;
    padding: 0.25rem 0.5rem;
    margin-top: calc(var(--space-xs) - 0.25rem);
    margin-left: auto;
  }
  .toc nav {
    height: fit-content;
    border-left: 1px solid var(--color-border);
    padding-left: var(--toc-pad);
  }
  .toc-heading {
    margin: 0 0 var(--space-md);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .item {
    position: relative;
    line-height: 1.45;
    margin-top: var(--space-sm);
  }
  .item.depth-2 {
    font-size: 1rem;
  }
  .item.depth-3 {
    font-size: 0.875rem;
    padding-left: var(--space-sm);
  }
  .item a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s linear;
  }
  .item a:hover {
    color: var(--color-text);
  }
  /* Current-position marker: a rounded bar sitting on the left track. */
  .item.active::before {
    content: "";
    position: absolute;
    left: calc(-1 * var(--toc-pad) - 1px);
    top: 0.2em;
    bottom: 0.2em;
    width: 3px;
    background: var(--color-primary);
    border-radius: 999px;
  }
  .item.active a {
    color: var(--color-primary);
  }
  @media (min-width: 68.75rem) {
    .toc {
      display: block;
    }
  }
</style>
