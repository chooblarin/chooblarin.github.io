---
import logo from "@/assets/images/logo.svg?raw";
---

<a href="/">
  <Fragment set:html={logo} />
</a>

<style>
  a {
    border-radius: 4px;
    color: var(--ds-color-text);
  }

  a:focus {
    outline: none;
  }

  a:focus-visible {
    outline: var(--ds-focus-ring-width) solid var(--ds-color-focus-ring);
    outline-offset: var(--ds-focus-ring-offset);
  }
</style>
