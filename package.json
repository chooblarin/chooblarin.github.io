{
  "name": "chooblarin.github.io",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "content:lint": "node scripts/content-lint.mjs",
    "content:lint:strict": "node scripts/content-lint.mjs --strict",
    "content:fix:description": "node scripts/backfill-description.mjs",
    "textlint": "textlint \"docs/**/*.md\" \"src/content/post/**/*.{md,mdx}\"",
    "textlint:fix": "textlint --fix \"docs/**/*.md\" \"src/content/post/**/*.{md,mdx}\"",
    "textlint:strict": "npm run textlint",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/svelte": "^7.2.5",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@rive-app/canvas": "^2.34.1",
    "astro": "^5.16.11",
    "date-fns": "^4.1.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "svelte": "^5.46.4",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@textlint/textlint-plugin-markdown": "^15.5.2",
    "prettier": "^3.8.0",
    "prettier-plugin-astro": "^0.14.1",
    "textlint": "^15.5.2",
    "textlint-filter-rule-comments": "^1.3.0",
    "textlint-plugin-mdx": "^1.0.2",
    "textlint-rule-common-misspellings": "^1.0.1",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2"
  }
}
