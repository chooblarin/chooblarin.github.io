{
  "filters": {
    "comments": true
  },
  "plugins": {
    "@textlint/markdown": true,
    "mdx": true
  },
  "rules": {
    "preset-ja-technical-writing": {
      "no-mix-dearu-desumasu": {
        "preferInHeader": "",
        "preferInBody": "ですます",
        "preferInList": "ですます",
        "strict": false
      }
    },
    "common-misspellings": true
  }
}
